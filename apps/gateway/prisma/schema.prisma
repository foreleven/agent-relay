// Gateway Prisma schema – SQLite backing store
// Run `prisma generate` after changes; use `prisma db push` to sync the schema.

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model Account {
  id           String         @id @default(uuid())
  username     String         @unique
  passwordHash String?        @map("password_hash")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  credentials AccountCredentials[]

  @@map("accounts")
}

model AccountCredentials {
  id                String    @id @default(uuid())
  accountId         String    @map("account_id")
  provider          String
  providerAccountId String    @map("provider_account_id")
  accessToken       String?   @map("access_token")
  refreshToken      String?   @map("refresh_token")
  expiresAt         DateTime? @map("expires_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([provider, providerAccountId])
  @@map("account_credentials")
}

model ChannelBinding {
  id            String   @id @default(uuid())
  name          String
  channelType   String   @map("channel_type")
  accountId     String   @map("account_id")
  channelConfig String   @default("{}") @map("channel_config")
  agentId       String   @map("agent_id")
  sessionIsolationStrategy String   @default("sessionKey") @map("session_isolation_strategy")
  enabledKey    String?  @unique @map("enabled_key")
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  messages      Message[]
  scheduledJobs ScheduledJob[]

  @@index([agentId])
  @@map("channel_bindings")
}

model Agent {
  id          String   @id @default(uuid())
  name        String
  protocol    String   @default("a2a")
  config      String   @default("{}")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  bindings        ChannelBinding[]
  sessionMappings SessionMapping[]

  @@map("agents")
}

model SessionMapping {
  id                String   @id @default(uuid())
  agentId           String   @map("agent_id")
  protocol          String
  sessionKey        String   @map("session_key")
  protocolSessionId String   @map("protocol_session_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([agentId, protocol, sessionKey])
  @@index([protocol, protocolSessionId])
  @@map("session_mappings")
}

model RuntimeNode {
  nodeId           String   @id @map("node_id")
  displayName      String   @map("display_name")
  mode             String
  lastKnownAddress String   @map("last_known_address")
  registeredAt     DateTime @default(now()) @map("registered_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  @@map("runtime_nodes")
}

model Message {
  id               String   @id @default(uuid())
  channelBindingId String   @map("channel_binding_id")
  direction        String
  channelType      String   @map("channel_type")
  accountId        String   @map("account_id")
  sessionKey       String   @map("session_key")
  content          String
  metadata         String   @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")

  channelBinding ChannelBinding @relation(fields: [channelBindingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([channelBindingId, createdAt])
  @@index([channelType, accountId, createdAt])
  @@map("messages")
}

model ScheduledJob {
  id               String   @id @default(uuid())
  name             String
  channelBindingId String   @map("channel_binding_id")
  sessionKey       String   @map("session_key")
  prompt           String
  cronExpression   String   @map("cron_expression")
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  channelBinding ChannelBinding @relation(fields: [channelBindingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("scheduled_jobs")
}
